{
  "name": "metrh-website",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "node --max-old-space-size=4096 ./node_modules/nuxt/bin/nuxt.mjs build",
    "dev": "nuxt dev",
    "generate": "node --max-old-space-size=4096 ./node_modules/nuxt/bin/nuxt.mjs generate",
    "preview": "nuxt preview",
    "prepare": "nuxt prepare",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxt typecheck",
    "db:types": "supabase gen types typescript --project-id $SUPABASE_PROJECT_ID --schema public > types/database.types.ts"
  },
  "dependencies": {
    "@fontsource/plus-jakarta-sans": "^5.2.8",
    "@fontsource/poppins": "^5.2.7",
    "@nuxt/icon": "^2.2.2",
    "@nuxtjs/supabase": "^2.0.7",
    "@supabase/supabase-js": "^2.45.0",
    "@tailwindcss/vite": "^4.3.0",
    "@vueuse/nuxt": "^14.3.0",
    "nuxt": "^4.4.5",
    "tailwindcss": "^4.3.0",
    "vue": "^3.5.34",
    "vue-router": "^5.0.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "typescript": "^6.0.3",
    "vue-tsc": "^3.2.8"
  }
}
